from playwright.sync_api import Page, expect
from pages.login_page import LoginPage
from pages.inventory_page import InventoryPage

def test_sort_products_price_high_to_low(page: Page):
    """
    ID: TC010
    Escenario: Ordenamiento por Precio (High to Low)
    Resultado Esperado: Los productos deben mostrarse organizados de mayor a menor precio.
    """
    login = LoginPage(page)
    inventory = InventoryPage(page)

    # 1. Precondición: Acceso e inicio de sesión
    page.goto("https://www.saucedemo.com/")
    login.login_to_app("standard_user", "secret_sauce")

    # 2. Acción: Seleccionar el filtro "Price (high to low)"
    # El valor interno en el HTML para esta opción es 'hilo'
    inventory.sort_dropdown.select_option("hilo")

    # 3. Extracción: Capturar los precios de la interfaz
    raw_prices = inventory.page.locator(".inventory_item_price").all_inner_texts()

    # 4. Transformación: Limpieza de símbolos y conversión a float
    cleaned_prices = [float(p.replace("$", "")) for p in raw_prices]

    # 5. Validación: Comparar contra orden descendente (reverse=True)
    expected_order = sorted(cleaned_prices, reverse=True)
    
    assert cleaned_prices == expected_order, f"El orden descendente falló. Obtenido: {cleaned_prices}"
