from playwright.sync_api import Page, expect
from pages.login_page import LoginPage
from pages.inventory_page import InventoryPage

def test_sort_products_price_low_to_high(page: Page):
    """
    ID: TC009
    Escenario: Ordenamiento por Precio (Low to High)
    Resultado Esperado: Los productos deben mostrarse organizados de menor a mayor precio.
    """
    login = LoginPage(page)
    inventory = InventoryPage(page)

    # 1. Precondición: Acceso e inicio de sesión
    page.goto("https://www.saucedemo.com/")
    login.login_to_app("standard_user", "secret_sauce")

    # 2. Acción: Seleccionar el filtro "Price (low to high)"
    # El valor interno en el HTML para esta opción es 'lohi'
    inventory.sort_dropdown.select_option("lohi")

    # 3. Extracción: Capturar todos los precios visibles
    raw_prices = inventory.page.locator(".inventory_item_price").all_inner_texts()

    # 4. Transformación: Quitar el '$' y convertir a números flotantes
    cleaned_prices = [float(p.replace("$", "")) for p in raw_prices]

    # 5. Validación: Comparar la lista obtenida contra una lista ordenada por Python
    expected_order = sorted(cleaned_prices) # Por defecto es ascendente
    
    assert cleaned_prices == expected_order, f"El orden ascendente falló. Obtenido: {cleaned_prices}"
